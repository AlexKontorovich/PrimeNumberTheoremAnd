/*
====================================================================
 PRIME MATRIX EVOLUTION ENGINE
 Ultra Fast Autonomous Matrix Builder
 VS Code Compatible
====================================================================

MAIN EQUATION

    x = 2(phi(x,a) + a + n - 1) - 3

WHERE

    a = pi(sqrt(x))

====================================================================
 MATRIX RULE
====================================================================

Example:

n = 1 -> 3 5 7
n = 2 -> 9 11 13
n = 3 -> 15 17 19
n = 4 -> 21 23
n = 5 -> 25

Logic:

- x starts from 3
- x increases by +2
- if equation balances:
     continue same row
- otherwise:
     move to next n

====================================================================
 FEATURES
====================================================================

1- Fully autonomous
2- No external prime lists
3- No external constants
4- Self-growing primes
5- Self-growing phi cache
6- Auto save
7- Auto resume
8- Ultra fast binary storage
9- Continuous matrix generation
10- Infinite expansion architecture

====================================================================
 FILES
====================================================================

prime_memory.dat
phi_memory.dat
engine_state.dat
matrix_output.txt

====================================================================
*/

#include <iostream>
#include <vector>
#include <unordered_map>
#include <fstream>
#include <algorithm>
#include <cmath>
#include <memory>
#include <iomanip>

using namespace std;

/* ================================================================
   Phi Key
================================================================ */

struct PhiKey
{
    uint64_t x;

    uint32_t a;

    bool operator==(const PhiKey& other) const
    {
        return
            x == other.x
            &&
            a == other.a;
    }
};

/* ================================================================
   Hash
================================================================ */

struct PhiHash
{
    size_t operator()(const PhiKey& k) const
    {
        return
            hash<uint64_t>()(k.x)
            ^
            (hash<uint32_t>()(k.a) << 1);
    }
};

/* ================================================================
   Engine State
================================================================ */

struct EngineState
{
    uint64_t current_n;

    uint64_t current_x;
};

/* ================================================================
   Solution Structure
================================================================ */

struct Solution
{
    uint64_t n;

    uint64_t x;
};

/* ================================================================
   Main Engine
================================================================ */

class PrimeMatrixEngine
{
private:

    vector<uint64_t> primes;

    unordered_map<PhiKey,uint64_t,PhiHash> phi_cache;

    vector<Solution> write_buffer;

    EngineState state;

private:

    const string PRIME_FILE =
        "prime_memory.dat";

    const string PHI_FILE =
        "phi_memory.dat";

    const string STATE_FILE =
        "engine_state.dat";

    const string MATRIX_FILE =
        "matrix_output.txt";

private:

    /* ============================================================
       Load State
    ============================================================ */

    void load_state()
    {
        ifstream in(
            STATE_FILE,
            ios::binary
        );

        if(!in)
        {
            state.current_n = 1;

            state.current_x = 3;

            return;
        }

        in.read(
            (char*)&state,
            sizeof(EngineState)
        );
    }

    /* ============================================================
       Save State
    ============================================================ */

    void save_state()
    {
        ofstream out(
            STATE_FILE,
            ios::binary
        );

        out.write(
            (char*)&state,
            sizeof(EngineState)
        );
    }

    /* ============================================================
       Load Primes
    ============================================================ */

    void load_primes()
    {
        ifstream in(
            PRIME_FILE,
            ios::binary
        );

        if(!in)
            return;

        size_t sz;

        in.read(
            (char*)&sz,
            sizeof(sz)
        );

        primes.resize(sz);

        in.read(
            (char*)primes.data(),
            sz * sizeof(uint64_t)
        );

        cout
        << "Loaded "
        << primes.size()
        << " primes."
        << endl;
    }

    /* ============================================================
       Save Primes
    ============================================================ */

    void save_primes()
    {
        ofstream out(
            PRIME_FILE,
            ios::binary
        );

        size_t sz = primes.size();

        out.write(
            (char*)&sz,
            sizeof(sz)
        );

        out.write(
            (char*)primes.data(),
            sz * sizeof(uint64_t)
        );
    }

    /* ============================================================
       Load Phi Cache
    ============================================================ */

    void load_phi_cache()
    {
        ifstream in(
            PHI_FILE,
            ios::binary
        );

        if(!in)
            return;

        size_t sz;

        in.read(
            (char*)&sz,
            sizeof(sz)
        );

        for(size_t i=0;i<sz;i++)
        {
            PhiKey key;

            uint64_t value;

            in.read(
                (char*)&key,
                sizeof(PhiKey)
            );

            in.read(
                (char*)&value,
                sizeof(uint64_t)
            );

            phi_cache[key] = value;
        }

        cout
        << "Loaded "
        << phi_cache.size()
        << " phi values."
        << endl;
    }

    /* ============================================================
       Save Phi Cache
    ============================================================ */

    void save_phi_cache()
    {
        ofstream out(
            PHI_FILE,
            ios::binary
        );

        size_t sz = phi_cache.size();

        out.write(
            (char*)&sz,
            sizeof(sz)
        );

        for(auto const& item : phi_cache)
        {
            out.write(
                (char*)&item.first,
                sizeof(PhiKey)
            );

            out.write(
                (char*)&item.second,
                sizeof(uint64_t)
            );
        }
    }

public:

    /* ============================================================
       Constructor
    ============================================================ */

    PrimeMatrixEngine()
    {
        load_state();

        load_primes();

        load_phi_cache();

        if(primes.empty())
        {
            primes.push_back(2);

            primes.push_back(3);
        }

        cout << endl;

        cout
        << "===================================="
        << endl;

        cout
        << "ENGINE RESUMED"
        << endl;

        cout
        << "Current N = "
        << state.current_n
        << endl;

        cout
        << "Current X = "
        << state.current_x
        << endl;

        cout
        << "===================================="
        << endl;
    }

    /* ============================================================
       Destructor
    ============================================================ */

    ~PrimeMatrixEngine()
    {
        flush_buffer();

        save_state();

        save_primes();

        save_phi_cache();

        cout
        << "ALL MEMORY SAVED"
        << endl;
    }

public:

    /* ============================================================
       Prime Test
    ============================================================ */

    bool is_prime(uint64_t n)
    {
        if(n < 2)
            return false;

        for(uint64_t p : primes)
        {
            if(p * p > n)
                break;

            if(n % p == 0)
                return false;
        }

        return true;
    }

    /* ============================================================
       Self Growing Prime Database
    ============================================================ */

    void grow_primes_until(uint64_t limit)
    {
        uint64_t current =
            primes.back();

        if(current % 2 == 0)
            current++;
        else
            current += 2;

        while(primes.back() < limit)
        {
            if(is_prime(current))
            {
                primes.push_back(current);

                if(primes.size() % 100000 == 0)
                {
                    cout
                    << "Prime Count = "
                    << primes.size()
                    << endl;
                }
            }

            current += 2;
        }
    }

    /* ============================================================
       pi(x)
    ============================================================ */

    uint64_t pi_function(uint64_t x)
    {
        return
            upper_bound(
                primes.begin(),
                primes.end(),
                x
            )
            -
            primes.begin();
    }

    /* ============================================================
       Phi(x,a)
    ============================================================ */

    uint64_t phi(uint64_t x,uint32_t a)
    {
        if(x == 0)
            return 0;

        if(a == 0)
            return x;

        PhiKey key = {x,a};

        auto it = phi_cache.find(key);

        if(it != phi_cache.end())
        {
            return it->second;
        }

        uint64_t result =
            phi(x,a-1)
            -
            phi(
                x / primes[a-1],
                a-1
            );

        phi_cache[key] = result;

        return result;
    }

    /* ============================================================
       Equation
    ============================================================ */

    uint64_t equation_rhs(
        uint64_t x,
        uint64_t n
    )
    {
        uint32_t a =
            (uint32_t)
            pi_function(
                (uint64_t)
                sqrt((long double)x)
            );

        return
            2 *
            (
                phi(x,a)
                +
                a
                +
                n
                -
                1
            )
            -
            3;
    }

    /* ============================================================
       Matrix Rule
    ============================================================ */

    bool valid_solution(
        uint64_t n,
        uint64_t x
    )
    {
        // المعادلة نفسها تصنع مصفوفة صحيحة تلقائياً بدون الحاجة لشروط الأولية هنا
        // إرجاع القيمة true يضمن طباعة كافة قيم n إلى ما لا نهاية كما في مثالك
        return true;
    }

    /* ============================================================
       Add Solution
    ============================================================ */

    void add_solution(
        uint64_t n,
        uint64_t x
    )
    {
        write_buffer.push_back({n,x});

        cout
        << "N="
        << setw(8)
        << n
        << "  X="
        << setw(12)
        << x
        << endl;

        /* ========================================================
            Ultra Fast Flush
         ======================================================== */

        if(write_buffer.size() >= 1000000)
        {
            flush_buffer();
        }
    }

    /* ============================================================
       Flush Buffer
    ============================================================ */

    void flush_buffer()
    {
        if(write_buffer.empty())
            return;

        ofstream out(
            MATRIX_FILE,
            ios::app
        );

        uint64_t current_n = 0;

        for(auto const& s : write_buffer)
        {
            if(s.n != current_n)
            {
                current_n = s.n;

                out << endl;

                out
                << "n="
                << current_n
                << " -> ";
            }

            out
            << s.x
            << " ";
        }

        out << endl;

        write_buffer.clear();

        cout
        << "BUFFER FLUSHED"
        << endl;
    }

    /* ============================================================
       Main Infinite Engine
    ============================================================ */

    void run()
    {
        while(true)
        {
            uint64_t n =
                state.current_n;

            uint64_t x =
                state.current_x;

            /* ====================================================
                Self Growth
            ==================================================== */

            if(x > primes.back())
            {
                grow_primes_until(x * 2);
            }

            uint64_t lhs = x;

            uint64_t rhs =
                equation_rhs(x,n);

            /* ====================================================
                Equation Balanced
            ==================================================== */

            if(lhs == rhs)
            {
                bool valid =
                    valid_solution(n,x);

                if(valid)
                {
                    add_solution(n,x);
                }

                state.current_x += 2;
            }
            else
            {
                cout << endl;

                cout
                << "--------------------------------"
                << endl;

                cout
                << "MOVING TO N = "
                << (state.current_n + 1)
                << endl;

                cout
                << "--------------------------------"
                << endl;

                state.current_n++;
            }

            /* ====================================================
                Auto Save
            ==================================================== */

            static uint64_t last_saved_n = 0;

            if(state.current_n > 0 && state.current_n % 1000000 == 0 && state.current_n != last_saved_n)
            {
                last_saved_n = state.current_n;

                flush_buffer();

                save_state();

                save_primes();

                save_phi_cache();

                cout
                << "1 MILLION N REACHED - AUTO SAVE COMPLETE"
                << endl;

                cout
                << "Prime Count = "
                << primes.size()
                << endl;

                cout
                << "Phi Cache = "
                << phi_cache.size()
                << endl;
            }

            /* ====================================================
                Cache Cleanup
            ==================================================== */

            if(phi_cache.size() > 50000000)
            {
                cout
                << "Cleaning Phi Cache..."
                << endl;

                phi_cache.clear();
            }
        }
    }
};

/* ================================================================

   MAIN
================================================================ */

int main()
{
    ios::sync_with_stdio(false);

    cin.tie(nullptr);

    auto engine =
        make_unique<PrimeMatrixEngine>();

    engine->run();

    return 0;
}
